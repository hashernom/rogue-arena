{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm install && pnpm --filter @rogue-arena/shared build && pnpm --filter @rogue-arena/server build"
  },
  "deploy": {
    "startCommand": "pnpm --filter @rogue-arena/server start",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
